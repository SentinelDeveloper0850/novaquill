# NovaQuill environment example
# Copy this file to .env.local and replace placeholder values.
#
# Linux/macOS:
#   cp .env.example .env.local
#
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32

# -----------------------------------------------------------------------------
# Core app + auth (required)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/novaquill?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-32-byte-base64-secret"
STORAGE_ENCRYPTION_KEY="replace-with-32-byte-base64-key"
NODE_ENV="development"

# Public site URL used for metadata/open graph (optional)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Security + ops (optional)
# -----------------------------------------------------------------------------
# Comma-separated hosts (without scheme), e.g. "localhost:3000,app.example.com"
ALLOWED_ORIGINS="localhost:3000"

# Comma-separated admin emails for /api/analytics GET
ADMIN_EMAILS="admin@example.com"

# Optional Redis for distributed rate limiting/health checks
REDIS_URL=""

# -----------------------------------------------------------------------------
# OAuth providers (optional)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# PayFast subscriptions (required for paid plans)
# -----------------------------------------------------------------------------
PAYFAST_ENV="sandbox"
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""

# -----------------------------------------------------------------------------
# S3 document storage (optional; leave blank for encrypted local disk storage)
# -----------------------------------------------------------------------------
AWS_REGION=""
AWS_S3_BUCKET=""

# Use either static key credentials OR role-based credentials in your runtime.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_ROLE_ARN=""

# Optional S3-compatible endpoint/config
AWS_S3_ENDPOINT=""
AWS_S3_FORCE_PATH_STYLE="false"
