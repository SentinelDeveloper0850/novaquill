# App
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=
ALLOWED_ORIGINS=localhost:3000
ADMIN_EMAILS=

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/novaquill
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/novaquill

# Auth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Encryption
# Generate with: openssl rand -base64 32
STORAGE_ENCRYPTION_KEY=

# Cloudinary document storage
# Required in production. Signed PDFs are encrypted before upload.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis rate limiting
# Strongly recommended in production/serverless environments.
REDIS_URL=

# PayFast
PAYFAST_ENV=sandbox
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
