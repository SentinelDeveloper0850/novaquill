generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  savedSignatures SavedSignature[]

  // Subscription and usage tracking
  subscription  SubscriptionStatus @default(FREE)
  subscriptionPlan SubscriptionPlan?
  lastPaymentAt DateTime?
  payfastLastPaymentId String?
  docsUsedThisMonth Int            @default(0)
  usageYearMonth  Int?             // e.g., 202508 for August 2025
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

enum SubscriptionStatus {
  FREE
  PRO
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  path      String
  createdAt DateTime @default(now())
}

model SavedSignature {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  mimeType      String
  encryptedPayload Bytes
  hash          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@unique([userId, hash])
}

// Privacy-preserving analytics: simple counters by event name (no PII)
model EventCounter {
  name  String @id
  count Int    @default(0)
}

// PayFast notifications for idempotency/auditing (no cardholder data)
model PayfastEvent {
  id          String   @id @default(cuid())
  pfPaymentId String   @unique
  payload     Json
  createdAt   DateTime @default(now())
}


